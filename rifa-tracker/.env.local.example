# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Meta Ads API — nunca se expone al frontend (solo server-side)
# Token compartido para todas las cuentas publicitarias
META_ACCESS_TOKEN=YOUR_META_LONG_LIVED_TOKEN

# Cuenta por defecto (fallback si no usás el gestor de cuentas)
META_AD_ACCOUNT_ID=act_YOUR_ACCOUNT_ID

